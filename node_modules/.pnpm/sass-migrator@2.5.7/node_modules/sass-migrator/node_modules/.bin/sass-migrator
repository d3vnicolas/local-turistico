#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/nicolas/Documents/rocketseat/local-turistico/node_modules/.pnpm/sass-migrator@2.5.7/node_modules/sass-migrator/node_modules:/home/nicolas/Documents/rocketseat/local-turistico/node_modules/.pnpm/sass-migrator@2.5.7/node_modules:/home/nicolas/Documents/rocketseat/local-turistico/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/nicolas/Documents/rocketseat/local-turistico/node_modules/.pnpm/sass-migrator@2.5.7/node_modules/sass-migrator/node_modules:/home/nicolas/Documents/rocketseat/local-turistico/node_modules/.pnpm/sass-migrator@2.5.7/node_modules:/home/nicolas/Documents/rocketseat/local-turistico/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../sass-migrator.js" "$@"
else
  exec node  "$basedir/../../sass-migrator.js" "$@"
fi
